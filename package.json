{
  "name": "knowledge-base-qa-bot",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:server": "npm --workspace apps/server run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/server run build && npm --workspace apps/web run build",
    "import:raw": "npm --workspace apps/server run import:raw --",
    "eval": "npm --workspace apps/server run eval",
    "test:unit": "npm --workspace apps/server run test",
    "test:e2e": "npm --workspace apps/e2e run test"
  }
}
